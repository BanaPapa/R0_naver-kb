# Supabase 연결 (이 앱 전용 프로젝트)
# Supabase 대시보드 → Settings → API 에서 복사.
# 실제 값은 .env 에 넣으세요 (.env 는 .gitignore 됨). service_role 키는 절대 넣지 마세요.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 크롤 토큰 서명 키. 로컬 개발에서 /api/crawl-token(Vite 미들웨어)가 사용.
# Vercel 배포본은 동일 키를 Vercel 환경변수(CRAWL_TOKEN_SECRET)로 설정.
CRAWL_TOKEN_SECRET=

# ── 국토교통부 실거래가(실거래가 탭) ──────────────────────
# 공공데이터포털(data.go.kr) 실거래가 API 인증키(serviceKey).
# 서버측 프록시(dev: Vite /molit-api, prod: api/molit-proxy)에서만 사용 → 클라이언트 노출 금지.
# 반드시 VITE_ 접두사 없이 서버 전용으로 설정하세요. Vercel 환경변수에도 동일 키(MOLIT_API_KEY) 등록.
# 인코딩/디코딩 키 아무거나 가능(%포함=인코딩 키로 자동 판별).
MOLIT_API_KEY=

# ── KB 시계열 데이터 소스 ──────────────────────────────────
# 'static'(기본): public/data/*.json 사용. 추가 설정 없이 동작.
# 'supabase': Storage 번들 + 버전 캐시 사용(전량 메모리 모델 + 업데이트 진행률 모달).
VITE_KB_DATA_SOURCE=static
# KB 데이터 번들이 저장된 Storage 버킷명(기본 kb-data).
VITE_KB_DATA_BUCKET=kb-data

# ── ingest 전용(클라이언트 노출 금지, 로컬 셸/CI 시크릿으로만) ──
# scripts/kb-publish-bundles.mjs 가 번들을 Storage에 업로드할 때 사용하는 service_role 키.
# 절대 .env 로 커밋하거나 VITE_ 접두사로 노출하지 마세요.
# SUPABASE_SERVICE_ROLE_KEY=
