{
  "manifest_version": 3,
  "name": "Estate-OS 커넥터",
  "version": "2.2.0",
  "description": "Estate-OS 웹앱의 부동산 매물·시세·리뷰 조회를 사용자 브라우저에서 처리하도록 연결하는 확장입니다.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Estate-OS 커넥터",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "cookies",
    "storage",
    "webRequest",
    "declarativeNetRequestWithHostAccess",
    "tabs"
  ],
  "host_permissions": [
    "*://*.naver.com/*",
    "https://hogangnono.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "naver_headers",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://estate-os.xyz/*",
        "https://www.estate-os.xyz/*",
        "https://estate-os.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:5174/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
